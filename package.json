{
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "web:dev": "yarn workspace @liftledger/web dev",
    "web:build": "yarn workspace @liftledger/web build",
    "web:typecheck": "yarn workspace @liftledger/web typecheck",
    "web:test": "yarn workspace @liftledger/web test",
    "web:test:run": "yarn workspace @liftledger/web test:run",
    "api:dev": "yarn workspace @liftledger/api dev",
    "api:build": "yarn workspace @liftledger/api build",
    "api:start": "yarn workspace @liftledger/api start",
    "api:test": "yarn workspace @liftledger/api test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.18.1"
  }
}
