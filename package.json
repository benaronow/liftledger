{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "api:dev": "yarn workspace @liftledger/api dev",
    "api:build": "yarn workspace @liftledger/api build",
    "api:start": "yarn workspace @liftledger/api start",
    "api:test": "yarn workspace @liftledger/api test",
    "web:dev": "yarn workspace @liftledger/web dev",
    "web:build": "yarn workspace @liftledger/web build",
    "web:typecheck": "yarn workspace @liftledger/web typecheck"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.2.4",
    "@liftledger/api-client": "*",
    "@liftledger/shared": "*",
    "axios": "^1.7.9",
    "bootstrap": "5.3.8",
    "dayjs": "^1.11.13",
    "next": "^16.1.1",
    "react": "^19.2.1",
    "react-bootstrap": "^2.10.10",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "recharts": "^3.8.1",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "jsdom": "^29.0.2",
    "mongodb-memory-server": "^11.0.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.4"
  },
  "type": "module"
}
